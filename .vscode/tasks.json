{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "dev",
			"type": "npm",
			"script": "dev",
			"group": "build",
			"isBackground": true,
			"problemMatcher": [
				{
					"pattern": [
						{
							"regexp": ".",
							"file": 1,
							"location": 2,
							"message": 3
						}
					],
					"background": {
						"activeOnStart": true,
						"beginsPattern": {
							"regexp": "extension build start"
						},
						"endsPattern": {
							"regexp": "extension build success"
						}
					}
				}
			]
		}
	]
}
